# Copy to deploy/deploy.env (gitignored) and fill in. install.sh sources it.
# Secrets live here — keep it out of git and chmod 600.

# ── Public access (TLS + basic auth via Caddy) ──────────────────────────────
LOTSA_DOMAIN=lotsa.example.com        # DNS A-record must already point at this box
LOTSA_ADMIN_EMAIL=you@example.com     # for the Let's Encrypt account (recommended)
LOTSA_BASIC_USER=admin
LOTSA_BASIC_PASS=change-me-to-something-strong

# ── Agent credentials (headless — no keychain on a server) ──────────────────
# Set ONE of these. For the OAuth token: run `claude setup-token` locally.
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=
# Enables push + pull-request features. Scope it to a throwaway repo for demos.
GITHUB_TOKEN=

# ── Where Lotsa comes from ──────────────────────────────────────────────────
# Recommended (pre-push): a locally built wheel, scp'd to the box.
#   Local:  make build   →   scp dist/lotsa-*.whl root@box:/root/
LOTSA_WHEEL=/root/lotsa-0.1.0-py3-none-any.whl
# Or install from git instead (once the repo is published):
# LOTSA_GIT=https://github.com/lotsadev/lotsa.git

# ── Projects (the git repos Lotsa runs tasks against) ───────────────────────
# Space-separated id=url pairs. Private repos are cloned using GITHUB_TOKEN, so
# that token must have READ access to them (and write, for the PR demo).
#   PROJECT_REPOS="api=https://github.com/you/api.git web=https://github.com/you/web.git"
PROJECT_REPOS=""
# Single-repo shorthand (used only when PROJECT_REPOS is empty):
PROJECT_ID=demo
PROJECT_REPO=                          # empty → seeds an empty demo repo so doctor passes

LOTSA_MODEL=sonnet

# Per-agent-dispatch budget cap in USD. Optional — only applied when set (unset
# preserves lotsa init's default of 5.0, or a value you hand-edit in lotsa.yaml).
# Each step's agent run is capped at this; a task spends a multiple across steps.
# LOTSA_BUDGET=25
